DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Comma-separated list of trusted origins for board CSRF protection.
# If set, only requests from these origins will be allowed for board mutations.
# If not set, defaults to localhost dev origins (http://localhost:3100, http://127.0.0.1:3100).
# Example: PAPERCLIP_TRUSTED_ORIGINS=https://example.com,https://app.example.com
# PAPERCLIP_TRUSTED_ORIGINS=
